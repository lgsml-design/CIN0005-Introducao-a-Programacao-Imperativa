#include <stdio.h>
#include <string.h>
#include <ctype.h>

#define MAX_STR      105
#define MAX_WORDS     50
#define MAX_WORD_LEN 105

int main() {
    char s[MAX_STR];
    fgets(s, sizeof(s), stdin);
    s[strcspn(s, "\n")] = '\0'; // remove o '\n' que o fgets deixa no final

    // dois arrays "achatados": cada palavra ocupa MAX_WORD_LEN posições
    // palavras[]  = versão em minúsculas (usada pra comparar)
    // originais[] = versão como veio da entrada (usada pra exibir)
    char palavras [MAX_WORDS * MAX_WORD_LEN];
    char originais[MAX_WORDS * MAX_WORD_LEN];
    int count = 0;

    /* Extração das palavras */
    int i = 0, n = strlen(s);
    while (i < n && count < MAX_WORDS) {
        // pula tudo que não for letra (espaços, pontuação, etc.)
        while (i < n && !isalpha(s[i])) i++;
        if (i >= n) break;

        int j = 0;
        int base = count * MAX_WORD_LEN; // posição inicial dessa palavra nos arrays

        // copia caractere a caractere até acabar a palavra
        while (i < n && isalpha(s[i])) {
            palavras [base + j] = tolower(s[i]);
            originais[base + j] = s[i];
            j++;
            i++;
        }
        palavras [base + j] = '\0';
        originais[base + j] = '\0';
        count++;
    }

    /* Conta e exibe pares de anagramas */
    int total = 0;

    // primeira passagem: só conta quantos pares existem
    for (i = 0; i < count; i++) {
        for (int j = i + 1; j < count; j++) {
            char *a = palavras + i * MAX_WORD_LEN;
            char *b = palavras + j * MAX_WORD_LEN;

            // anagrama: mesmos caracteres, mesma frequência
            // começa assumindo que sim, e tenta refutar
            int anagrama = (strlen(a) == strlen(b)); // tamanhos diferentes já eliminam
            if (anagrama) {
                int freq[26] = {0};
                for (int k = 0; a[k]; k++) freq[a[k] - 'a']++; // conta letras de 'a'
                for (int k = 0; b[k]; k++) freq[b[k] - 'a']--; // desconta letras de 'b'
                for (int k = 0; k < 26; k++)
                    if (freq[k] != 0) { anagrama = 0; break; } // sobrou diferença
            }
            if (anagrama) total++;
        }
    }

    if (total == 0) {
        printf("Nao existem anagramas na frase.\n");
    } else {
        printf("Pares de anagramas encontrados:\n");

        // segunda passagem: agora imprime os pares (mesma lógica de verificação)
        for (i = 0; i < count; i++) {
            for (int j = i + 1; j < count; j++) {
                char *a = palavras + i * MAX_WORD_LEN;
                char *b = palavras + j * MAX_WORD_LEN;

                int anagrama = (strlen(a) == strlen(b));
                if (anagrama) {
                    int freq[26] = {0};
                    for (int k = 0; a[k]; k++) freq[a[k] - 'a']++;
                    for (int k = 0; b[k]; k++) freq[b[k] - 'a']--;
                    for (int k = 0; k < 26; k++)
                        if (freq[k] != 0) { anagrama = 0; break; }
                }

                // exibe com a grafia original, não a versão em minúsculas
                if (anagrama)
                    printf("%s e %s\n",
                           originais + i * MAX_WORD_LEN,
                           originais + j * MAX_WORD_LEN);
            }
        }
        printf("\nTotal de pares: %d\n", total);
    }

    return 0;
}
