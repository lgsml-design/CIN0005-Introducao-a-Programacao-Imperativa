#include <stdio.h>

int main() {
    // Declaração das variáveis
    int total;                 // Valor inicial a ser dividido
    int x, y, z;               // Porcentagens que cada um deve receber
    int investimento = 0;      // Quantidade adicionada ao total (0 a 3) para facilitar a divisão
    int impossivel = 0;        // Flag (bandeira) para indicar se a divisão exata não foi possível
    int efetuado = 0;          // Flag para indicar se a divisão foi bem-sucedida
    float A = 0, B = 0, C = 0; // Valores finais calculados para cada pessoa

    // Lê o valor total e as três porcentagens
    scanf("%d %d %d %d", &total, &x, &y, &z);

    // Bloco principal de cálculo (o 'if (1)' apenas cria um escopo, não tem efeito condicional real)
    if (1) {
        // Tenta a divisão com o valor original (investimento = 0)
        A = (float)total * x / 100;
        B = (float)total * y / 100;
        C = (float)total * z / 100;

        // Verifica se os valores resultantes são inteiros exatos
        if (A == (int)A && B == (int)B && C == (int)C) {
            efetuado = 1;
        } else {
            // Se não deu certo, tenta adicionar 1 ao total (investimento = 1)
            int t1 = total + 1;
            float A1 = (float)t1 * x / 100;
            float B1 = (float)t1 * y / 100;
            float C1 = (float)t1 * z / 100;
            
            // Verifica se deu exato E se a sobra (t1 - soma das partes) é maior que o investimento (1)
            if (A1 == (int)A1 && B1 == (int)B1 && C1 == (int)C1 && 1 < (t1 - (A1 + B1 + C1))) {
                A = A1; B = B1; C = C1;
                investimento = 1;
                efetuado = 1;
            } else {
                // Se não deu, tenta adicionar 2 ao total (investimento = 2)
                int t2 = total + 2;
                float A2 = (float)t2 * x / 100;
                float B2 = (float)t2 * y / 100;
                float C2 = (float)t2 * z / 100;
                
                if (A2 == (int)A2 && B2 == (int)B2 && C2 == (int)C2 && 2 < (t2 - (A2 + B2 + C2))) {
                    A = A2; B = B2; C = C2;
                    investimento = 2;
                    efetuado = 1;
                } else {
                    // Por fim, tenta adicionar 3 ao total (investimento = 3)
                    int t3 = total + 3;
                    float A3 = (float)t3 * x / 100;
                    float B3 = (float)t3 * y / 100;
                    float C3 = (float)t3 * z / 100;
                    
                    if (A3 == (int)A3 && B3 == (int)B3 && C3 == (int)C3 && 3 < (t3 - (A3 + B3 + C3))) {
                        A = A3; B = B3; C = C3;
                        investimento = 3;
                        efetuado = 1;
                    } else {
                        // Se falhou mesmo adicionando 3, marca como impossível
                        impossivel = 1;
                    }
                }
            }
        }
    }

    // Exibe o resultado da tentativa de divisão
    if (impossivel == 0) {
        printf("Cada homem ficou com %d, %d e %d reais, respectivamente\n", (int)A, (int)B, (int)C);
    } else {
        printf("Nao foi dessa vez que Rebeka pode ajudar...\n");
    }

    // Eventos extras baseados na quantidade investida para a divisão dar certo
    if (investimento == 2) {
        // Se investiu 2, o problema pede para ler 3 letras e somar a posição delas no alfabeto
        char letra1, letra2, letra3;
        scanf(" %c %c %c", &letra1, &letra2, &letra3);
        // 'a' na tabela ASCII é 97. (letra - 'a' + 1) transforma 'a' em 1, 'b' em 2, etc.
        int soma = (letra1 - 'a' + 1) + (letra2 - 'a' + 1) + (letra3 - 'a' + 1);
        printf("%d\n", soma);
    }

    if (investimento == 3) {
        // Se investiu 3, lê 3 idades
        int idade1, idade2, idade3;
        scanf("%d %d %d", &idade1, &idade2, &idade3);
        
        // Se pelo menos uma das idades for múltipla de 3
        if ((idade1 % 3 == 0) || (idade2 % 3 == 0) || (idade3 % 3 == 0)) {
            // Soma a terça parte apenas das idades que são divisíveis por 3 (operador ternário)
            int soma_3 = (idade1 % 3 == 0 ? idade1 / 3 : 0)
                       + (idade2 % 3 == 0 ? idade2 / 3 : 0)
                       + (idade3 % 3 == 0 ? idade3 / 3 : 0);
            printf("%d\n", soma_3);
        }
    }

    // Cálculo final do dinheiro que sobra para a Rebeka
    int total_usado = total + investimento;
    int sobra = total_usado - (int)(A + B + C);
    // Rebeka tinha 3 reais iniciais. Ela subtrai o que investiu, e recebe a sobra da divisão.
    int dinheiro_rebeka = 3 - investimento + sobra;

    // Condição de vitória/derrota da personagem
    if (impossivel == 1 || dinheiro_rebeka < 7) {
        printf("E parece que Rebeka vai ter que voltar andando...\n");
    } else {
        printf("Ela conseguiu! Rebeka voltou para casa e apanhou da mae por sumir noite passada!\n");
    }

    return 0;
}
